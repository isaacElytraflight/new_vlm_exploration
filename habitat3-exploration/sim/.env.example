# Simulation-mode overrides (loaded only when connecting in "sim" mode).
# Copy to sim/.env for local tweaks. project.yaml values are the fallback.

# SIM_COMPOSE_FILE=sim/docker/docker-compose.yml
# SIM_CONTAINER_NAME=habitat3-sim
# SIM_NOVNC_ORIGIN=http://localhost:6080

# --- EGL / rendering fallbacks for WSL2 (uncomment only if the smoke test fails) ---
# __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json
# HSIM_DISABLE_CUDA_DEVICE=1

# noVNC live-view frame rate (explore episode only; default 15, try 30 for smoother)
# HABITAT_VIEW_FPS=30

# Quieter habitat logs
# MAGNUM_LOG=quiet
# HABITAT_SIM_LOG=quiet
