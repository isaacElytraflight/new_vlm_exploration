# Simulation-mode overrides (loaded only when connecting in "sim" mode).
# Copy to sim/.env for local tweaks. Elytra Bridge loads this file on sim connect.
# Precedence: sim/.env, then Elytra Bridge backend .env, then project.yaml.

# SIM_COMPOSE_FILE=sim/docker/docker-compose.yml
# SIM_COMPOSE_PROJECT=habitat3-exploration
# SIM_CONTAINER_NAME=habitat3-sim
# SIM_NOVNC_ORIGIN=http://localhost:6080

# --- VLM (frontier selection) -------------------------------------------------
# Default: local Ollama on the host (no cloud API key required).
# 1. Install Ollama for Windows: https://ollama.com
# 2. Pull the model: ollama pull qwen2.5vl:3b
# 3. Ensure Ollama is running before starting an exploration episode.
#
# VLM_BACKEND=local
# VLM_OLLAMA_URL=http://host.docker.internal:11434
# VLM_LOCAL_MODEL=qwen3-vl:4b-instruct
# VLM_LOCAL_MAX_EDGE=512
# VLM_LOCAL_TIMEOUT_S=30
#
# Optional: use Gemini cloud instead (requires API key, subject to rate limits)
# VLM_BACKEND=gemini
# GEMINI_API_KEY=your-api-key-here

# --- EGL / rendering fallbacks for WSL2 (uncomment only if the smoke test fails) ---
# __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json
# HSIM_DISABLE_CUDA_DEVICE=1

# noVNC live-view frame rate (explore episode only; default 15, try 30 for smoother)
# HABITAT_VIEW_FPS=30

# Quieter habitat logs
# MAGNUM_LOG=quiet
# HABITAT_SIM_LOG=quiet
